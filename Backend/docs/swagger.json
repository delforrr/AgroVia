{
  "openapi": "3.0.0",
  "info": {
    "title": "AgroVia API",
    "version": "1.0.0",
    "description": "Documentación de la API para la plataforma AgroVia"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "schemas": {
      "Aviso": {
        "type": "object",
        "required": [
          "categoria",
          "titulo",
          "precio"
        ],
        "properties": {
          "categoria": {
            "type": "string",
            "example": "Hacienda"
          },
          "titulo": {
            "type": "string",
            "example": "50 cabezas terneros Hereford – 180 kg"
          },
          "descripcion": {
            "type": "string",
            "example": "Terneros de excelente calidad."
          },
          "precio": {
            "type": "number",
            "example": 550000
          },
          "moneda": {
            "type": "string",
            "example": "ARS"
          },
          "provincia": {
            "type": "string",
            "example": "Córdoba"
          },
          "localidad": {
            "type": "string",
            "example": "Río Cuarto"
          },
          "vendedor": {
            "type": "string",
            "example": "Juan Rodríguez"
          }
        }
      },
      "AvisoUpdate": {
        "type": "object",
        "properties": {
          "categoria": {
            "type": "string"
          },
          "titulo": {
            "type": "string"
          },
          "precio": {
            "type": "number"
          },
          "moneda": {
            "type": "string"
          }
        }
      },
      "Negociacion": {
        "type": "object",
        "required": [
          "aviso_id",
          "comprador_id",
          "oferta",
          "moneda"
        ],
        "properties": {
          "aviso_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "comprador_id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "oferta": {
            "type": "number",
            "example": 550000
          },
          "moneda": {
            "type": "string",
            "example": "ARS"
          },
          "estado": {
            "type": "string",
            "example": "Pendiente"
          }
        }
      },
      "NegociacionUpdate": {
        "type": "object",
        "properties": {
          "oferta": {
            "type": "number"
          },
          "estado": {
            "type": "string",
            "example": "Aceptada"
          }
        }
      }
    }
  },
  "paths": {
    "/api/avisos": {
      "get": {
        "summary": "Obtener todos los avisos",
        "description": "Retorna la lista completa de avisos (Hacienda, Maquinaria, Granos, Servicios) disponibles.",
        "tags": [
          "Avisos"
        ],
        "responses": {
          "200": {
            "description": "Operación exitosa"
          }
        }
      },
      "post": {
        "summary": "Agregar un nuevo aviso",
        "description": "Agrega un nuevo aviso a la base de datos",
        "tags": [
          "Avisos"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Aviso"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Aviso creado exitosamente"
          }
        }
      }
    },
    "/api/avisos/{id}": {
      "get": {
        "summary": "Obtener un aviso por ID",
        "description": "Devuelve un único aviso que coincida con el ID proporcionado.",
        "tags": [
          "Avisos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID del aviso",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Operación exitosa"
          },
          "404": {
            "description": "Aviso no encontrado"
          }
        }
      },
      "put": {
        "summary": "Actualiza un aviso por ID",
        "description": "Modifica uno o más campos de un aviso existente.",
        "tags": [
          "Avisos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID del aviso a modificar",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AvisoUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Aviso actualizado"
          },
          "404": {
            "description": "Aviso no encontrado"
          }
        }
      },
      "delete": {
        "summary": "Eliminar un aviso",
        "description": "Elimina un aviso de forma permanente de la base de datos.",
        "tags": [
          "Avisos"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID del aviso a eliminar",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Aviso eliminado correctamente"
          },
          "404": {
            "description": "Aviso no encontrado"
          }
        }
      }
    },
    "/api/negociaciones": {
      "get": {
        "summary": "Obtener todas las negociaciones",
        "description": "Retorna la lista completa de negociaciones disponibles.",
        "tags": [
          "Negociaciones"
        ],
        "responses": {
          "200": {
            "description": "Operación exitosa"
          }
        }
      },
      "post": {
        "summary": "Agregar una nueva negociación",
        "description": "Agrega una nueva negociación a la base de datos",
        "tags": [
          "Negociaciones"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Negociacion"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Negociación creada exitosamente"
          }
        }
      }
    },
    "/api/negociaciones/{id}": {
      "get": {
        "summary": "Obtener una negociación por ID",
        "description": "Devuelve una única negociación que coincida con el ID proporcionado.",
        "tags": [
          "Negociaciones"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID de la negociación",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Operación exitosa"
          },
          "404": {
            "description": "Negociación no encontrada"
          }
        }
      },
      "put": {
        "summary": "Actualiza una negociación por ID",
        "description": "Modifica uno o más campos de una negociación existente.",
        "tags": [
          "Negociaciones"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID de la negociación a modificar",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NegociacionUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Negociación actualizada"
          },
          "404": {
            "description": "Negociación no encontrada"
          }
        }
      },
      "delete": {
        "summary": "Eliminar una negociación",
        "description": "Elimina una negociación de forma permanente de la base de datos.",
        "tags": [
          "Negociaciones"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "UUID de la negociación a eliminar",
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Negociación eliminada correctamente"
          },
          "404": {
            "description": "Negociación no encontrada"
          }
        }
      }
    }
  }
}